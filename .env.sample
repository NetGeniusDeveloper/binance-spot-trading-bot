# ==================================================
# Scanner agent Telegram sender safety flags
# ==================================================
# Real Telegram sending is disabled unless BOTH flags are true.
SCANNER_TELEGRAM_SEND_ENABLED="false"
SCANNER_TELEGRAM_MANUAL_CONFIRM="false"
