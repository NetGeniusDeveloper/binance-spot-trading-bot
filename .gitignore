# ==================================================
# Python cache
# ==================================================
__pycache__/
*.py[cod]
*$py.class

# ==================================================
# Virtual environments
# ==================================================
.venv/
venv/
env/

# ==================================================
# Environment secrets
# ==================================================
.env
.env.local
.env.*.local

# Keep example environment file in Git
!.env.sample

# ==================================================
# Telegram local session files
# ==================================================
*.session
*.session-journal
crypto_scanner_session.session
crypto_scanner_session.session-journal

# ==================================================
# Local reports and runtime outputs
# ==================================================
reports/*.json
reports/*.txt
reports/*.log
reports/*.db
reports/*.sqlite
reports/*.sqlite3

# Keep recommended/generated Python config previews if needed
!reports/scanner_real_channels.recommended.py
!reports/scanner_real_channels.backup.py

# ==================================================
# Local database files
# ==================================================
data/social_scanner.db
data/*.db
data/*.sqlite
data/*.sqlite3

# ==================================================
# Logs
# ==================================================
*.log
logs/

# ==================================================
# OS / editor files
# ==================================================
.DS_Store
Thumbs.db
*.swp
*.swo
*.save
*.bak
*.backup

# ==================================================
# Local test artifacts
# ==================================================
.pytest_cache/
.coverage
htmlcov/

# ==================================================
# Local patch/temp files
# ==================================================
execute-times.tmp
patch_*.py

# ==================================================
# Local markdown reports
